# MongoDB
MONGO_URL="mongodb://localhost:27017"
DB_NAME="mychat_db"
CORS_ORIGINS="*"

# Meta / Instagram OAuth (get from https://developers.facebook.com)
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_VERIFY_TOKEN=mychat_verify_123

# JWT secret (generate random: openssl rand -hex 32)
JWT_SECRET=change_me_to_random_32_byte_hex

# URLs (for local dev)
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8001
